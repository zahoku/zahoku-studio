---
import { STUDIO } from '../lib/identity';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/about', label: 'About' },
  { href: '/projects/', label: 'Projects' },
  { href: '/play/', label: 'Play' },
] as const;
---

<header class="w-full border-b border-[var(--color-line)]">
  <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
    <a
      href="/"
      class="text-sm font-semibold tracking-tight hover:text-[var(--color-accent)] transition-colors"
    >
      {STUDIO.nameKo}
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="px-3 py-1.5 rounded-md text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] hover:bg-[var(--color-line)] transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
