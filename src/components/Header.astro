---
import { STUDIO } from '../lib/identity';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;

const links = [
  { href: '/', label: 'home', match: (p: string) => p === '/' },
  { href: '/projects/', label: 'project', disabled: true, match: (p: string) => p.startsWith('/projects') },
  { href: '/play/', label: 'play', match: (p: string) => p.startsWith('/play') },
] as const;
---

<header class="w-full border-b border-[var(--color-line)] bg-[var(--color-paper)]/70 backdrop-blur-sm">
  <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
    <a
      href="/"
      class="text-sm font-medium tracking-tight font-mono hover:text-[var(--color-accent)] transition-colors"
    >
      {STUDIO.slug}
    </a>
    <nav class="flex items-center gap-1 text-sm font-mono">
      {
        links.map((link) => {
          const active = link.match(path);
          if ('disabled' in link && link.disabled) {
            return (
              <span
                aria-disabled="true"
                class="px-3 py-1.5 rounded-md text-[var(--color-ink-soft)]/50 cursor-not-allowed select-none"
              >
                {link.label}
              </span>
            );
          }
          return (
            <a
              href={link.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'px-3 py-1.5 rounded-md transition-colors',
                active
                  ? 'text-[var(--color-ink)] bg-[var(--color-line)]'
                  : 'text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] hover:bg-[var(--color-line)]',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
