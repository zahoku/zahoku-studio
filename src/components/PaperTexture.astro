---
/**
 * 낡은 종이 질감 배경.
 * SVG turbulence noise를 화면 가득 깔아 종이 결을 만든다.
 * 한자 그래픽보다 아래 레이어 (z-index: -2).
 */
---

<div class="paper-texture" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" preserveAspectRatio="none">
    <filter id="paper-noise" x="0" y="0" width="100%" height="100%">
      <feTurbulence type="fractalNoise" baseFrequency="0.78" numOctaves="2" seed="7" stitchTiles="stitch" />
      <feColorMatrix
        type="matrix"
        values="0 0 0 0 0.22
                0 0 0 0 0.16
                0 0 0 0 0.10
                0 0 0 0.55 0"
      />
    </filter>
    <filter id="paper-fiber" x="0" y="0" width="100%" height="100%">
      <feTurbulence type="turbulence" baseFrequency="0.012 0.04" numOctaves="2" seed="3" />
      <feColorMatrix
        type="matrix"
        values="0 0 0 0 0.30
                0 0 0 0 0.22
                0 0 0 0 0.14
                0 0 0 0.18 0"
      />
    </filter>
    <rect width="100%" height="100%" filter="url(#paper-fiber)" />
    <rect width="100%" height="100%" filter="url(#paper-noise)" />
  </svg>

  <!-- 가장자리 vignette -->
  <div class="paper-vignette"></div>
</div>

<style>
  .paper-texture {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    overflow: hidden;
  }

  .paper-texture svg {
    width: 100%;
    height: 100%;
    opacity: 0.32;
    mix-blend-mode: multiply;
  }

  .paper-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 55%,
      color-mix(in srgb, var(--color-ink) 6%, transparent) 100%
    );
    pointer-events: none;
  }

  :root.dark .paper-texture svg,
  :where(:root:not(.light)) .paper-texture svg {
    opacity: 0.22;
    mix-blend-mode: screen;
  }
</style>
