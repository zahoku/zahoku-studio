---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STUDIO } from '../../lib/identity';

const title = `glyfy — ${STUDIO.nameKo}`;
const description = '한글·영문 타이핑 연습을 게임으로 풀어낸 웹 타이핑 게임. 자호쿠 스튜디오의 프로젝트.';
---

<BaseLayout title={title} description={description}>
  <header>
    <p class="text-sm tracking-widest text-[var(--color-ink-soft)] uppercase">Project</p>
    <h1 class="mt-2 text-4xl md:text-5xl font-semibold tracking-tight">glyfy</h1>
    <p class="mt-3 text-[var(--color-ink-soft)]">웹 타이핑 게임</p>
  </header>

  <section class="mt-12">
    <p class="text-lg text-[var(--color-ink-dim)] leading-relaxed">
      타이핑 연습을 부담 없이 즐길 수 있게 만든 웹 게임. 한글과 영문 모두 지원하며, 매일 짧게 즐기기 좋다.
    </p>
  </section>

  <section class="mt-12 p-6 border border-dashed border-[var(--color-line)] rounded-lg">
    <p class="text-sm text-[var(--color-ink-soft)]">
      현재 개발 중입니다. 출시 시점에 더 자세한 안내가 이곳에 올라옵니다.
    </p>
  </section>

  <p class="mt-12">
    <a
      href="/projects/"
      class="text-sm text-[var(--color-accent)] hover:underline underline-offset-4"
    >
      ← 프로젝트 목록
    </a>
  </p>
</BaseLayout>
