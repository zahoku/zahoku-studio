---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STUDIO } from '../../lib/identity';

const title = `haruip — ${STUDIO.nameKo}`;
const description = '하루를 자동으로 기록해주는 모바일 일기 앱. 자호쿠 스튜디오의 프로젝트.';
---

<BaseLayout title={title} description={description}>
  <header>
    <p class="text-sm tracking-widest text-[var(--color-ink-soft)] uppercase">Project</p>
    <h1 class="mt-2 text-4xl md:text-5xl font-semibold tracking-tight">haruip</h1>
    <p class="mt-3 text-[var(--color-ink-soft)]">자동 일기 앱</p>
  </header>

  <section class="mt-12">
    <p class="text-lg text-[var(--color-ink-dim)] leading-relaxed">
      하루의 흐름을 자동으로 기록해 일기로 남겨주는 모바일 앱. 매일 적는 부담 없이 시간이 쌓이게 한다.
    </p>
  </section>

  <section class="mt-12 p-6 border border-dashed border-[var(--color-line)] rounded-lg">
    <p class="text-sm text-[var(--color-ink-soft)]">
      현재 개발 중입니다. 출시 시점에 더 자세한 안내가 이곳에 올라옵니다.
    </p>
  </section>

  <p class="mt-12">
    <a
      href="/projects/"
      class="text-sm text-[var(--color-accent)] hover:underline underline-offset-4"
    >
      ← 프로젝트 목록
    </a>
  </p>
</BaseLayout>
