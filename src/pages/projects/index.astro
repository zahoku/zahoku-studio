---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STUDIO } from '../../lib/identity';

const title = `project — ${STUDIO.slug}`;
const description = `${STUDIO.slug} project. Coming soon.`;
---

<BaseLayout title={title} description={description}>
  <section class="py-12 md:py-20">
    <p class="text-xs font-mono tracking-widest text-[var(--color-ink-soft)] uppercase">project</p>
    <h1
      class="mt-4 font-serif text-5xl md:text-7xl leading-none tracking-tight text-[var(--color-ink)]"
    >
      Soon.
    </h1>
    <p class="mt-6 text-base md:text-lg text-[var(--color-ink-dim)] max-w-prose leading-relaxed">
      오래 갈 것을 본다. 길게 가는 일에 빠른 길은 없다.
    </p>
    <p class="mt-2 text-sm font-mono text-[var(--color-ink-soft)]">{STUDIO.motto.ko}.</p>
  </section>
</BaseLayout>
