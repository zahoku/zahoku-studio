---
/**
 * OG image용 standalone 페이지. 1200×630 정확히.
 * BaseLayout 사용 X — Header/Footer 없이 OG 캔버스 그대로.
 * dev에서 http://localhost:4321/og 로 확인 → Chrome devtools 캡처 → public/og-image.png 교체.
 */
import '../styles/global.css';
import { STUDIO } from '../lib/identity';

const title = `${STUDIO.slug} — OG`;
---

<!doctype html>
<html lang="ko" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1200" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
  </head>
  <body class="og-body">
    <div class="og-canvas">
      <!-- 한지 노이즈 텍스처 -->
      <svg class="paper-noise" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" preserveAspectRatio="none">
        <filter id="og-fiber" x="0" y="0" width="100%" height="100%">
          <feTurbulence type="turbulence" baseFrequency="0.012 0.04" numOctaves="2" seed="3" />
          <feColorMatrix
            type="matrix"
            values="0 0 0 0 0.30
                    0 0 0 0 0.22
                    0 0 0 0 0.14
                    0 0 0 0.18 0"
          />
        </filter>
        <filter id="og-grain" x="0" y="0" width="100%" height="100%">
          <feTurbulence type="fractalNoise" baseFrequency="0.78" numOctaves="2" seed="7" stitchTiles="stitch" />
          <feColorMatrix
            type="matrix"
            values="0 0 0 0 0.22
                    0 0 0 0 0.16
                    0 0 0 0 0.10
                    0 0 0 0.45 0"
          />
        </filter>
        <rect width="1200" height="630" filter="url(#og-fiber)" />
        <rect width="1200" height="630" filter="url(#og-grain)" />
      </svg>

      <!-- 가장자리 vignette -->
      <div class="vignette"></div>

      <!-- 자호구 한자 — 인주 도장 letterpress -->
      <div class="hanja-stamps" aria-hidden="true">
        <span class="hanja h1">自</span>
        <span class="hanja h2">好</span>
        <span class="hanja h3">久</span>
      </div>

      <!-- 좌상단 모서리 마크 -->
      <div class="top-corner">
        <span class="corner-label">自好久</span>
      </div>

      <!-- 하단 워드마크 + 영문 brand statement -->
      <div class="bottom-block">
        <p class="motto">{STUDIO.tagline}</p>
        <p class="wordmark">{STUDIO.slug}</p>
      </div>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
  }

  .og-body {
    background: #3f4b3f;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .og-canvas {
    width: 1200px;
    height: 630px;
    position: relative;
    overflow: hidden;
    background: #f2eede;
    color: #2a2520;
    font-family: var(--font-sans);
    isolation: isolate;
  }

  .paper-noise {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.3;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(42, 37, 32, 0.10) 100%);
    pointer-events: none;
  }

  /* 자호구 한자 letterpress — 인주 도장 톤 */
  .hanja-stamps {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .hanja {
    position: absolute;
    font-family: 'Noto Serif KR', var(--font-serif);
    font-weight: 900;
    line-height: 0.82;
    color: rgba(122, 111, 60, 0.88);
    user-select: none;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.18),
      0 -1px 0 rgba(0, 0, 0, 0.08);
    filter: contrast(1.05);
  }

  .h1 {
    font-size: 460px;
    top: -40px;
    left: -30px;
    transform: rotate(-7deg);
  }

  .h2 {
    font-size: 520px;
    top: 30px;
    left: 360px;
    transform: rotate(3deg);
  }

  .h3 {
    font-size: 480px;
    top: 80px;
    left: 760px;
    transform: rotate(-4deg);
  }

  /* 좌상단 모서리 마크 — 작은 한자 식별자 */
  .top-corner {
    position: absolute;
    top: 56px;
    left: 64px;
    z-index: 2;
  }

  .corner-label {
    font-family: var(--font-mono);
    font-size: 16px;
    letter-spacing: 0.3em;
    color: rgba(42, 37, 32, 0.55);
    text-transform: uppercase;
  }

  /* 하단 블록 — 모토 + 워드마크 */
  .bottom-block {
    position: absolute;
    bottom: 56px;
    left: 64px;
    right: 64px;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .motto {
    margin: 0;
    font-family: 'Noto Serif KR', var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    line-height: 1.25;
    color: #7a6f3c;
    letter-spacing: -0.005em;
    max-width: 820px;
  }

  .wordmark {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 18px;
    letter-spacing: 0.05em;
    color: rgba(42, 37, 32, 0.55);
    white-space: nowrap;
  }
</style>
