---
import BaseLayout from '../layouts/BaseLayout.astro';
import { HANJA_BREAKDOWN, STUDIO } from '../lib/identity';

const title = `소개 — ${STUDIO.nameKo}`;
const description = `${STUDIO.nameKo}의 정체성과 운영 원칙. 自好久 — 스스로 좋아하는 것을 오래도록.`;
---

<BaseLayout title={title} description={description}>
  <article class="prose-zahoku">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">소개</h1>
    <p class="mt-4 text-lg text-[var(--color-ink-dim)]">
      {STUDIO.nameKo}는 {STUDIO.founder}이 운영하는 1인 + AI 팀 스튜디오입니다.
    </p>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">이름의 유래</h2>
      <p class="mt-3 leading-relaxed text-[var(--color-ink-dim)]">
        <strong class="text-[var(--color-ink)]">자호쿠</strong>는 작성자의 인생 첫 아이디로, 약
        28년 전 인터넷 세상에 발 들이며 입에 붙는 어감으로 골랐던 이름입니다. 수십 년이 흐른 뒤,
        이 닉네임에 의미를 부여하는 과정에서
        <strong class="text-[var(--color-ink)]">자호구(自好久)</strong>라는 한자 조합을 발견했고, 그
        뜻이 추구해온 삶·일의 자세와 깊게 맞닿아 있어 공식 의미로 채택했습니다.
      </p>
      <p class="mt-3 leading-relaxed text-[var(--color-ink-dim)]">
        발음은 자호구의 일본식 음독을 부드럽게 굴린 <strong class="text-[var(--color-ink)]"
          >자호쿠 / Zahoku / ザホク</strong
        >로 통일합니다.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">한자 풀이</h2>
      <div class="mt-4 space-y-3">
        {
          HANJA_BREAKDOWN.map((hanja) => (
            <div class="flex items-start gap-4 border border-[var(--color-line)] rounded-lg p-4">
              <div class="text-4xl font-serif text-[var(--color-accent)] leading-none">
                {hanja.char}
              </div>
              <div class="flex-1">
                <div class="text-sm">
                  <span class="font-medium">{hanja.ko}</span>
                  <span class="text-[var(--color-ink-soft)] ml-2">/ {hanja.jp}</span>
                </div>
                <div class="mt-1 text-sm">{hanja.meaning}</div>
                <div class="mt-1 text-xs text-[var(--color-ink-soft)]">{hanja.nuance}</div>
              </div>
            </div>
          ))
        }
      </div>
      <blockquote class="mt-6 border-l-2 border-[var(--color-accent)] pl-4 italic">
        스스로 좋아하는 것을 오래도록 한다.
      </blockquote>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">운영 원칙</h2>
      <dl class="mt-4 space-y-4">
        <div>
          <dt class="font-medium">
            <span class="font-serif text-[var(--color-accent)] mr-2">自</span>스스로
          </dt>
          <dd class="mt-1 text-sm text-[var(--color-ink-dim)] pl-7">
            AI를 팀원으로 둔 1인 스튜디오. 외주·고용이 아닌 자기 의지로 만든다.
          </dd>
        </div>
        <div>
          <dt class="font-medium">
            <span class="font-serif text-[var(--color-accent)] mr-2">好</span>좋아하는 것
          </dt>
          <dd class="mt-1 text-sm text-[var(--color-ink-dim)] pl-7">
            트래픽·매출 지표 이전에, 인간을 이롭게 하는 가치와 만드는 사람이 진심으로 좋아하는 것을
            우선한다.
          </dd>
        </div>
        <div>
          <dt class="font-medium">
            <span class="font-serif text-[var(--color-accent)] mr-2">久</span>오래
          </dt>
          <dd class="mt-1 text-sm text-[var(--color-ink-dim)] pl-7">
            빠른 출시·유행 추종보다, 오래 지속될 가치와 꾸준한 운영을 우선한다.
          </dd>
        </div>
      </dl>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">분야</h2>
      <ul class="mt-3 space-y-2 text-[var(--color-ink-dim)]">
        <li>웹 서비스</li>
        <li>모바일 앱</li>
        <li>웹 기반 미니 게임</li>
      </ul>
    </section>
  </article>
</BaseLayout>
