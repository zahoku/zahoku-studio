---
import '../styles/global.css';
import { STUDIO } from '../lib/identity';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{STUDIO.nameKo} — {STUDIO.motto.ko}</title>
    <meta name="description" content={STUDIO.shortDescription.ko} />
  </head>
  <body class="min-h-dvh flex items-center justify-center px-6">
    <main class="text-center">
      <h1 class="text-4xl md:text-6xl font-semibold tracking-tight">{STUDIO.nameKo}</h1>
      <p class="mt-6 text-lg md:text-xl text-[var(--color-ink-dim)]">{STUDIO.motto.ko}.</p>
    </main>
  </body>
</html>
