---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STUDIO } from '../lib/identity';

const title = `${STUDIO.slug}`;
---

<BaseLayout title={title} description={STUDIO.shortDescription}>
  <section class="hero">
    <h1 class="wordmark">ZAHOKU-STUDIO</h1>
    <p class="tagline">{STUDIO.tagline}</p>
  </section>

  {/* works 섹션 — 공개 시점 미정. 정리 전까지 숨김. */}
  {/*
  <section class="works">
    <ul>
      {
        WORKS.map((work) => (
          <li class="work">
            <span class="work-link work-soon">
              <span class="work-name">{work.name}</span>
              <span class="work-kind">{work.kind}</span>
              <span class="work-status">soon</span>
            </span>
          </li>
        ))
      }
    </ul>
  </section>
  */}

  <section class="contact">
    <a href={`mailto:${STUDIO.contact}`} class="contact-link">{STUDIO.contact}</a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: clamp(16px, 2vh, 32px);
    padding-bottom: clamp(16px, 2vh, 28px);
  }

  .wordmark {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--color-brand);
  }

  .tagline {
    margin: 18px 0 0;
    font-family: 'Noto Serif KR', var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--color-accent-soft);
    max-width: 600px;
    letter-spacing: -0.005em;
  }

  /* Works */
  .works {
    padding-top: clamp(16px, 2vh, 28px);
    padding-bottom: clamp(16px, 2vh, 28px);
    border-top: 1px solid color-mix(in srgb, var(--color-line) 60%, transparent);
  }

  .works ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .work {
    margin: 0;
  }

  .work-link {
    display: grid;
    grid-template-columns: minmax(120px, 180px) 1fr auto;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-line) 35%, transparent);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1), color 300ms;
  }

  a.work-link:hover {
    color: var(--color-accent-soft);
    transform: translateX(6px);
  }

  .work-name {
    font-family: 'Noto Serif KR', var(--font-serif);
    font-weight: 600;
    font-size: clamp(20px, 2.4vw, 28px);
    letter-spacing: -0.01em;
  }

  .work-kind {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-ink-dim);
  }

  .work-arrow,
  .work-status {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--color-ink-soft);
    text-transform: uppercase;
  }

  .work-soon {
    cursor: default;
    color: var(--color-ink-dim);
  }

  .work-soon .work-name {
    color: var(--color-ink-dim);
  }

  /* Contact */
  .contact {
    padding-top: clamp(16px, 2vh, 28px);
    padding-bottom: 4px;
  }

  .contact-link {
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: 0.05em;
    color: var(--color-ink-dim);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-line) 80%, transparent);
    padding-bottom: 2px;
    transition: color 300ms;
  }

  .contact-link:hover {
    color: var(--color-accent-soft);
  }

  @media (max-width: 640px) {
    .work-link {
      grid-template-columns: 1fr auto;
      gap: 6px 12px;
    }

    .work-name {
      grid-column: 1 / -1;
    }

    .work-kind {
      grid-column: 1;
    }

    .work-arrow,
    .work-status {
      grid-column: 2;
      align-self: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-link {
      transition: color 300ms !important;
      transform: none !important;
    }
    a.work-link:hover {
      transform: none !important;
    }
  }
</style>
