---
import BaseLayout from '../layouts/BaseLayout.astro';
import { HANJA_BREAKDOWN, STUDIO } from '../lib/identity';

const title = `${STUDIO.nameKo} — ${STUDIO.motto.ko}`;
---

<BaseLayout title={title} description={STUDIO.shortDescription.ko}>
  <section class="pt-8 md:pt-16">
    <p class="text-sm tracking-widest text-[var(--color-ink-soft)] uppercase">
      {STUDIO.nameEn}
    </p>
    <h1 class="mt-3 text-5xl md:text-7xl font-semibold tracking-tight leading-[1.1]">
      {STUDIO.nameKo}
    </h1>
    <p class="mt-8 text-xl md:text-2xl text-[var(--color-ink-dim)] leading-relaxed">
      {STUDIO.motto.ko}.
    </p>
  </section>

  <section class="mt-20 md:mt-28">
    <h2 class="text-xs tracking-widest text-[var(--color-ink-soft)] uppercase mb-6">
      自好久 — 자호구
    </h2>
    <div class="grid grid-cols-3 gap-4 md:gap-8">
      {
        HANJA_BREAKDOWN.map((hanja) => (
          <div class="border border-[var(--color-line)] rounded-lg p-4 md:p-6">
            <div class="text-4xl md:text-5xl font-serif text-[var(--color-accent)]">
              {hanja.char}
            </div>
            <div class="mt-3 text-sm font-medium">{hanja.meaning}</div>
            <div class="mt-1 text-xs text-[var(--color-ink-soft)]">{hanja.nuance}</div>
          </div>
        ))
      }
    </div>
    <p class="mt-8 text-base md:text-lg text-[var(--color-ink-dim)] leading-relaxed">
      자기가 진심으로 좋아하는 길을 길게 간다. AI를 팀원으로 한 1인 스튜디오로서,
      트래픽·매출 지표 이전에 <strong class="text-[var(--color-ink)]"
        >인간을 이롭게 하는 가치</strong
      >와 <strong class="text-[var(--color-ink)]">오래 지속될 가치</strong>를 만든다.
    </p>
    <p class="mt-6">
      <a
        href="/about"
        class="text-sm font-medium text-[var(--color-accent)] hover:underline underline-offset-4"
      >
        스튜디오 소개 →
      </a>
    </p>
  </section>
</BaseLayout>
