---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STUDIO } from '../../lib/identity';

const title = `play — ${STUDIO.slug}`;
const description = `${STUDIO.slug} play. Short, simple web mini-games.`;
---

<BaseLayout title={title} description={description}>
  <section class="py-12 md:py-20">
    <p class="text-xs font-mono tracking-widest text-[var(--color-ink-soft)] uppercase">play</p>
    <h1
      class="mt-4 font-serif text-5xl md:text-7xl leading-none tracking-tight text-[var(--color-ink)]"
    >
      Soon.
    </h1>
    <p class="mt-6 text-base md:text-lg text-[var(--color-ink-dim)] max-w-prose leading-relaxed">
      Short. Simple. Made to enjoy in a minute.
    </p>
    <p class="mt-2 text-sm text-[var(--color-ink-dim)]">짧고 단순한 웹 미니게임. 1분이면 충분.</p>
  </section>
</BaseLayout>
